# ─── Development Dockerfile (hot-reload) ─────────────────────────────────────
FROM node:24-alpine

WORKDIR /app

# Install ALL dependencies (including devDependencies)
COPY package*.json ./
RUN npm ci

# Copy config files needed by NestJS CLI
# Source code is bind-mounted at runtime via docker-compose.dev.yml
COPY tsconfig*.json nest-cli.json ./
COPY src ./src

EXPOSE 8000

CMD ["npm", "run", "start:docker"]
