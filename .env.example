# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=8000
API_URL=http://localhost:8000
APP_PREFIX=v1
APP_NAME=CoreNest
CORS_ORIGINS=http://localhost:8000

# CSRF secret — must be at least 32 characters
CSRF_SECRET=change-me-to-a-random-string-of-at-least-32-chars

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# ─── Database ─────────────────────────────────────────────────────────────────
# When running via docker-compose, DB_HOST must match the postgres service name
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-me
DB_DATABASE=core_nest
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_SSL=false

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Both secrets must be at least 32 characters
JWT_SECRET=change-me-to-a-random-secret-of-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-a-different-random-secret-32-chars
JWT_REFRESH_EXPIRES_IN=7d
